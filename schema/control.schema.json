{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compliance-framework/schema/control.schema.json",
  "title": "Compliance Control Definition",
  "description": "Schema for individual control files within a framework",
  "type": "object",
  "required": [
    "id",
    "family",
    "title"
  ],
  "properties": {
    "id": {
      "type": [
        "string",
        "number"
      ],
      "description": "Control identifier (e.g., 'ac-2', 'a5.15', 'art-7', 164.404)"
    },
    "family": {
      "type": "string",
      "description": "Control family identifier (e.g., 'ac', 'a5', 'cap-2')"
    },
    "title": {
      "type": "string",
      "description": "Control title"
    },
    "class": {
      "type": "string",
      "description": "Source standard class (e.g., 'SP800-53', 'ISO27001')"
    },
    "baselines": {
      "type": [
        "array",
        "object"
      ],
      "items": {
        "type": "string"
      },
      "description": "Which baselines include this control (array of IDs or object with per-level details)"
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "guidance": {
            "type": "string"
          }
        }
      }
    },
    "statement": {
      "type": "object",
      "properties": {
        "prose": {
          "type": "string",
          "description": "Full text of the control statement"
        },
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "prose": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "guidance": {
      "type": "object",
      "properties": {
        "prose": {
          "type": "string"
        }
      }
    },
    "enhancements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "baselines": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "citation": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "implementation_guidance": {
      "type": "object",
      "description": "Practical implementation guidance per technology domain",
      "properties": {
        "platform_engineering": {
          "$ref": "#/$defs/techstack_guidance"
        },
        "devsecops": {
          "$ref": "#/$defs/techstack_guidance"
        },
        "secops": {
          "$ref": "#/$defs/techstack_guidance"
        },
        "gitops": {
          "$ref": "#/$defs/techstack_guidance"
        },
        "cloud_native": {
          "$ref": "#/$defs/techstack_guidance"
        }
      }
    },
    "legal_references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "framework_id"
        ],
        "properties": {
          "framework_id": {
            "type": "string"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relationship": {
            "type": "string",
            "enum": [
              "supports",
              "implements",
              "equivalent-to",
              "derived-from",
              "complements",
              "mapped",
              "intersects-with",
              "extends",
              "similar-to"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "techstack_guidance": {
      "type": "object",
      "properties": {
        "prose": {
          "type": "string",
          "description": "Implementation guidance text"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Relevant tools for implementation"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "language": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compliance-framework/schema/mapping.schema.json",
  "title": "Cross-Framework Control Mapping",
  "description": "Schema for mapping controls between compliance frameworks",
  "type": "object",
  "required": ["id", "source_framework", "target_framework", "mappings"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique mapping identifier"
    },
    "title": {
      "type": "string",
      "description": "Human-readable mapping title"
    },
    "source_framework": {
      "type": "string",
      "description": "Source framework ID"
    },
    "target_framework": {
      "type": "string",
      "description": "Target framework ID"
    },
    "version": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "methodology": {
      "type": "string",
      "enum": ["syntactic", "semantic", "functional", "structural"],
      "description": "Mapping methodology used"
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_control", "target_controls"],
        "properties": {
          "source_control": {
            "type": "string",
            "description": "Control ID in the source framework"
          },
          "target_controls": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "relationship"],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Control ID in the target framework"
                },
                "relationship": {
                  "type": "string",
                  "enum": ["equivalent-to", "subset-of", "superset-of", "intersects-with", "derived-from", "complements", "implements"],
                  "description": "OSCAL-compatible relationship type"
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Confidence score (0.0-1.0)"
                },
                "rationale": {
                  "type": "string",
                  "description": "Explanation of the mapping relationship"
                }
              }
            }
          }
        }
      }
    }
  }
}

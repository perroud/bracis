{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compliance-framework/schema/framework.schema.json",
  "title": "Compliance Framework Metadata",
  "description": "Schema for compliance framework metadata files (framework.yaml)",
  "type": "object",
  "required": ["id", "title", "version", "authority", "type", "scope", "original_language"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Unique identifier (kebab-case)"
    },
    "title": {
      "type": "string",
      "description": "Full official name of the framework"
    },
    "short_title": {
      "type": "string",
      "description": "Abbreviated name for display"
    },
    "version": {
      "type": "string",
      "description": "Current version of the framework"
    },
    "publication_date": {
      "type": "string",
      "format": "date",
      "description": "Original publication date (YYYY-MM-DD)"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date (YYYY-MM-DD)"
    },
    "authority": {
      "type": "object",
      "required": ["name", "country"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the issuing body"
        },
        "acronym": {
          "type": "string",
          "description": "Acronym of the issuing body"
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code or 'INTL' for international"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Official URL of the issuing body or framework"
        }
      }
    },
    "type": {
      "type": "string",
      "enum": ["standard", "regulation", "law", "guideline", "benchmark", "directive", "resolution", "executive-order", "framework", "circular", "joint-resolution", "normative-instruction", "decree", "doctrine"],
      "description": "Classification of the framework"
    },
    "scope": {
      "type": "string",
      "enum": ["cybersecurity", "privacy", "data-protection", "financial", "operational", "supply-chain", "ai-governance", "cloud-security", "industrial-control", "physical-security", "risk-management", "quality-management", "environmental", "accessibility", "anti-money-laundering", "application-security", "open-banking", "open-insurance", "instant-payments-security", "crypto-assets-regulation", "investment-funds", "organized-markets", "incident-notification", "national-cybersecurity-policy", "information-security-governance-federal", "information-security-operational-processes", "cloud-computing-security-federal", "telemedicine", "electronic-health-records", "health-information-exchange", "software-as-medical-device", "computerized-systems-pharma", "artificial-intelligence-medicine", "classified-information", "cybercrime", "data-protection-enforcement", "digital-government", "electronic-signatures", "freedom-of-information", "sustainability-reporting", "good-manufacturing-practices-data-integrity", "administrative-sanctions", "equity-crowdfunding", "electronic-prescription", "defense", "telecommunications"],
      "description": "Primary focus area"
    },
    "mandatory": {
      "type": "boolean",
      "description": "Whether compliance is legally required (true for laws/regulations)"
    },
    "original_language": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[a-z]{2})?$",
      "description": "Original language code (e.g., 'en', 'pt-br')"
    },
    "available_languages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2}(-[a-z]{2})?$"
      },
      "description": "Available translation languages"
    },
    "industries": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Applicable industry sectors (references industries/*.yaml)"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Applicable geographic regions (references regions/*.yaml)"
    },
    "techstacks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Applicable technology domains (references techstacks/*.yaml)"
    },
    "baselines": {
      "type": "array",
      "items": {
        "type": ["object", "string"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "inherits_from": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "Impact levels or tiers within the framework"
    },
    "control_families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "control_count": { "type": "integer" }
        }
      }
    },
    "related_frameworks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["framework_id", "relationship"],
        "properties": {
          "framework_id": { "type": "string" },
          "relationship": {
            "type": "string",
            "enum": ["mapped", "derived-from", "supersedes", "superseded-by", "complements", "supports", "equivalent-to", "implements", "extends"]
          },
          "mapping_file": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
